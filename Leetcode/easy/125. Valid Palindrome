class Solution {
    public boolean isPalindrome(String s) {
        int left=0;
        int right=s.length()-1;
        s=s.toLowerCase();
        System.out.println('9'+0);
        while(left<=right){
            while((s.charAt(left)<97 || s.charAt(left)>122)&& (left<right) && (s.charAt(left)<48 || s.charAt(left)>57) ){
                left++;
            }
            while((s.charAt(right)<97 || s.charAt(right)>122)&& (left<right)&& (s.charAt(right)<48 || s.charAt(right)>57)){
                right--;
            }
            if(s.charAt(left)!=s.charAt(right)){
                return false;
            }
            left++;
            right--;
        }
        return true;
        
    }
}
