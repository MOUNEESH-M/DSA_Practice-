class Solution {
    public int maxProfit(int[] prices) {
        int profit=0;
        int min=10000;
        int maxprofit=0;
        for(int i:prices){
            min=Math.min(min,i);
            profit=i-min;
            maxprofit=Math.max(profit,maxprofit);
        }
        return maxprofit;
    }
}
