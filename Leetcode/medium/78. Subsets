class Solution {
    public List<List<Integer>> subsets(int[] nums) {
        List<List<Integer>> arr=new ArrayList<>();
        List<Integer> temp=new ArrayList<>();
        return helper(nums,0,temp);
        
    }
    public static List<List<Integer>> helper(int[] nums,int n,List<Integer> temp){
        if(n==nums.length){
            List<List<Integer>> arr=new ArrayList<>();
            List<Integer> ans=new ArrayList<>(temp);
            arr.add(ans);
            return arr;
        }
        
        temp.add(nums[n]);
        List<List<Integer>> left=helper(nums,n+1,temp);
        temp.remove(temp.size()-1);
        List<List<Integer>> right=helper(nums,n+1,temp);
        left.addAll(right);
        return left;
    }

}
